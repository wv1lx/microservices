<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-order-statuses" author="dev">
        <createTable tableName="order_statuses">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-orders" author="dev">
        <createTable tableName="orders">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status_id" type="BIGINT">
                <constraints foreignKeyName="fk_orders_status" references="order_statuses(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-insert-statuses" author="dev">
        <insert tableName="order_statuses">
            <column name="name" value="NEW"/>
        </insert>
        <insert tableName="order_statuses">
            <column name="name" value="PROCESSING"/>
        </insert>
        <insert tableName="order_statuses">
            <column name="name" value="COMPLETED"/>
        </insert>
        <insert tableName="order_statuses">
            <column name="name" value="CANCELLED"/>
        </insert>
    </changeSet>

</databaseChangeLog>