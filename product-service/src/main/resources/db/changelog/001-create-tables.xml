<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-categories" author="dev">
        <createTable tableName="categories">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-products" author="dev">
        <createTable tableName="products">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_products_category" references="categories(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-insert-categories" author="dev">
        <insert tableName="categories">
            <column name="name" value="Electronics"/>
        </insert>
        <insert tableName="categories">
            <column name="name" value="Clothing"/>
        </insert>
        <insert tableName="categories">
            <column name="name" value="Food"/>
        </insert>
        <insert tableName="categories">
            <column name="name" value="Books"/>
        </insert>
    </changeSet>

</databaseChangeLog>