<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-notification-types" author="dev">
        <createTable tableName="notification_types">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-notifications" author="dev">
        <createTable tableName="notifications">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type_id" type="BIGINT">
                <constraints foreignKeyName="fk_notifications_type" references="notification_types(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-insert-types" author="dev">
        <insert tableName="notification_types">
            <column name="name" value="EMAIL"/>
        </insert>
        <insert tableName="notification_types">
            <column name="name" value="SMS"/>
        </insert>
        <insert tableName="notification_types">
            <column name="name" value="PUSH"/>
        </insert>
    </changeSet>

</databaseChangeLog>